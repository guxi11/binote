{
  "name": "roammem",
  "version": "0.1.4",
  "description": "Bidirectional-linked project memory system for AI, exposed as MCP server",
  "type": "module",
  "bin": {
    "roammem": "dist/index.js"
  },
  "files": [
    "dist",
    "commands",
    ".claude-plugin"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "sync-version": "node scripts/sync-version.mjs",
    "change": "changenotes add",
    "changes": "changenotes list",
    "changes:preview": "changenotes preview",
    "version": "npm run sync-version && changenotes release $npm_package_version && git add .claude-plugin CHANGELOG.md .changes",
    "release": "npm version patch && git push --follow-tags && npm publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "globby": "^14.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "changenotes": "^0.1.1",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "mcp",
    "memory",
    "bidirectional-links",
    "roam",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guxi11/roammem.git"
  }
}
